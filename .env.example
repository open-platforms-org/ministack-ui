# MiniStack UI — variáveis de ambiente

# Seu usuário do Docker Hub (para publicar as imagens)
DOCKER_USER=seunome

# Endpoint do MiniStack/LocalStack no projeto
MINISTACK_ENDPOINT=http://ministack:4566

# Região AWS
AWS_REGION=us-east-1

# Porta da UI (mude se conflitar com sua aplicação)
FRONTEND_PORT=3030
BACKEND_PORT=3001

# Nome da rede Docker do projeto que está rodando o MiniStack
# Para descobrir: docker network ls
MINISTACK_NETWORK=dockerfiles_core-network

